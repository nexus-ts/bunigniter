# Application environment
# Copy this file to .env and fill in your values.

# Server
PORT=3000

# Database (bun-sqlite, postgres, mysql, sqlite, d1)
DB_DIALECT=bun-sqlite
DB_FILENAME=app.db
# DB_HOST=localhost
# DB_PORT=5432
# DB_USER=postgres
# DB_PASSWORD=
# DB_NAME=myapp

# Router
ROUTER_PREFIX=/api

# Application
# Generate with: bun -e "console.log(btoa(crypto.getRandomValues(new Uint8Array(32))))"
APP_KEY=
DEBUG=true
