{
  "name": "bunigniter",
  "version": "0.3.1",
  "description": "Bun-native fullstack framework — CodeIgniter spirit × Elysia performance × Edge-ready",
  "homepage": "https://github.com/nexus-ts/bunigniter",
  "type": "module",
  "files": [
    "dist/",
    "README.md",
    "LICENSE"
  ],
  "main": "src/index.ts",
  "module": "src/index.ts",
  "exports": {
    ".": "./src/index.ts",
    "./base": "./src/base/index.ts",
    "./controller": "./src/base/controller.ts",
    "./helpers/env": "./src/helpers/env.ts",
    "./helpers/validator": "./src/helpers/validator.ts",
    "./helpers/http": "./src/helpers/http.ts",
    "./helpers/image": "./src/helpers/image.ts",
    "./helpers/pagination": "./src/helpers/pagination.ts",
    "./helpers/session": "./src/helpers/session.ts",
    "./helpers/cache": "./src/helpers/cache.ts",
    "./helpers/queue": "./src/helpers/queue.ts",
    "./helpers/upload": "./src/helpers/upload.ts",
    "./helpers/mail": "./src/helpers/mail.ts",
    "./helpers/modules": "./src/helpers/modules.ts",
    "./helpers/openapi": "./src/helpers/openapi.ts",
    "./helpers/jwt": "./src/helpers/jwt.ts",
    "./helpers/ws": "./src/helpers/ws.ts",
    "./helpers/sse": "./src/helpers/sse.ts",
    "./helpers/schedule": "./src/helpers/schedule.ts",
    "./helpers/cors": "./src/helpers/cors.ts",
    "./helpers/csrf": "./src/helpers/csrf.ts",
    "./helpers/debug": "./src/helpers/debug.ts",
    "./helpers/handler": "./src/helpers/handler.ts",
    "./helpers/logger": "./src/helpers/logger.ts",
    "./helpers/middleware": "./src/helpers/middleware.ts",
    "./helpers/middleware-loader": "./src/helpers/middleware-loader.ts",
    "./helpers/request": "./src/helpers/request.ts",
    "./helpers/request-context": "./src/helpers/request-context.ts",
    "./helpers/session-middleware": "./src/helpers/session-middleware.ts",
    "./helpers/throttle": "./src/helpers/throttle.ts",
    "./router/file-router": "./src/router/file-router.ts",
    "./router/server-router": "./src/router/server-router.ts",
    "./view/page": "./src/view/page.ts",
    "./view/view-response": "./src/view/view-response.ts"
  },
  "scripts": {
    "build:dist": "bun run scripts/build-dist.ts",
    "prepublishOnly": "bun run build:dist",
    "postpublish": "rm -rf dist",
    "dev": "bun --hot run src/index.ts",
    "start": "bun run src/index.ts",
    "build": "bun build ./src/index.ts --outdir ./dist --target bun",
    "bi": "bun run src/cli/index.ts",
    "make:controller": "bun run src/cli/index.ts make:controller",
    "make:model": "bun run src/cli/index.ts make:model",
    "test": "bun x vitest run",
    "test:smoke": "bun x vitest run tests/smoke.test.ts",
    "test:unit": "bun x vitest run tests/ --exclude 'tests/smoke*' ",
    "typecheck": "tsc --noEmit",
    "lint": "biome check src/ tests/",
    "lint:fix": "biome check --write --unsafe src/ tests/",
    "format": "biome format --write src/ tests/"
  },
  "dependencies": {
    "drizzle-orm": "^0.45.0",
    "elysia": "2.0.0-exp.9",
    "openapi-types": "^12.1.3",
    "rendu": "^0.1.0",
    "sharp": "^0.35.2",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.5.1",
    "@types/bun": "^1.3.14",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@types/sharp": "^0.32.0",
    "playwright": "^1.61.1",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "typescript": "^5.7.0",
    "vitest": "^4.1.9"
  },
  "engines": {
    "bun": ">=1.3.0"
  },
  "license": "MIT"
}
